// -*- mode: jsonc -*-
{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    "width": 1920, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
     //Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
    ],
    //"modules-center": [
    //    "sway/window"
    //],
    "modules-right": [
        "pulseaudio",
        "network",
        "group/hardware",
        "backlight",
        "clock",
        "temperature",
        "battery",
	"custom/power"
    ],
    // Modules configuration
    "hyprland/workspaces": {
    //     "disable-scroll": true,
    //     "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{icon}",
         "format-icons": {
             "1": "≤░▓κ",
             "2": "≤░▓μ",
             "3": "≤░▓ξ",
             "4": "≤░▓π",
             "5": "≤░▓σ",
             "6": "≤░▓τ",
             "7": "≤░▓φ",
             "8": "≤░▓ψ",
             "9": "≤░▓▒",
             "urgent": "ΎΒς",
             "active": "ΎΕΣ",
             "default": "≤░αξ"
         }
     },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "group/hardware":{
        "modules":[
		"cpu",
		"memory",
		"disk"
		],
    	"orientation":"horizontal"
    },
    "cpu": {
        "format": "C {usage} / ",
        "tooltip": false
    },
    "memory": {
        "format": "M {} / "
    },
    "disk": {
        "interval": 30,
        "format": "S {percentage_used}",
        "path": "/",
        //"on-click": "~/dotfiles/.settings/systeminfo.sh"
    }, 
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["ΎΕΝ","ΎΒΓ","ΎΕΣ"],
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ΎΩπ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ΎΔπ",
        "performance": "ΎΔπ",
        "balanced": "ΎΚΟ",
        "power-saver": "ΎΒυ"
      }
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ ",
        "format-ethernet": "{ipaddr}/{cidr} ΎηΨ ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ ",
        "format-linked": "{ifname} (No IP) ΎηΨ ",
        "format-disconnected": "Disconnected έγι ",
//        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}", //"{format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        //"format-source": "{volume}% ΎΕ░",
        //"format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/power": {
        "format" : "έΠ╗",
	"on-click" : "wlogout"
    }
}
